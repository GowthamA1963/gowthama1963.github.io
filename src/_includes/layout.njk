<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title | default("Gowtham — Robotics Engineer") }}</title>

  <!-- Prism for code highlighting -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/style.css" />
</head>

<body>
 <!-- HERO: Mobile robot with manipulator -->
<section class="hero minimal-hero">
  <div class="hero-container">

    <div class="hero-left">
      <h1 class="hero-title">Gowtham</h1>
      <p class="hero-subtitle">Robotics Engineer • ROS2 • Navigation • Manipulation</p>

      <p class="hero-desc">
        I build autonomous mobile robots and manipulation systems — integrating navigation,
        perception, and embedded controllers for real-world robotics.
      </p>

      <div class="hero-buttons">
        <a href="/projects/" class="btn-primary">View Projects</a>
        <a href="/blog/" class="btn-secondary">Read Blog</a>
      </div>
    </div>

  </div>
</section>


  <!-- Header / Nav -->
  <header class="header">
    <div class="header-row">
      <div class="brand">
        <a class="brand-link" href="/"><span class="robot-mini" aria-hidden="true">🤖</span> Gowtham</a>
      </div>

      <nav class="nav">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/projects/">Projects</a>
        <a href="/blog/">Blog</a>
      </nav>

      <div class="controls">
        <button id="theme-toggle" class="theme-button" aria-label="Toggle dark mode">🌓</button>
      </div>
    </div>
    <hr class="divider"/>
  </header>

  <main class="site-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <hr class="divider"/>
    <p>Built with Eleventy • Robotics Edition • <a href="https://github.com/GowthamA1963/gowthama1963.github.io">repo</a></p>
  </footer>

  <!-- Prism JS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js"></script>

  <script>
    // Theme toggle script (persist)
    const btn = document.getElementById('theme-toggle');
    const root = document.documentElement;
    if (localStorage.getItem("theme") === "dark") root.classList.add("dark");

    btn.addEventListener("click", () => {
      root.classList.toggle("dark");
      localStorage.setItem("theme", root.classList.contains("dark") ? "dark" : "light");
    });

    // Small robot eye blink animation (class toggle)
    const eye = document.querySelector('.robot-eye');
    if (eye) {
      setInterval(() => {
        eye.style.transform = 'scaleY(0.2)';
        setTimeout(()=> eye.style.transform='scaleY(1)', 120);
      }, 5000);
    }
  </script>
</body>
</html>
